PORT=8080
MAX_ATTEMPTS=5
LOCKOUT_WINDOW_MS=60000
# TURN settings (Milestone 4). TURN_SECRET must equal coturn's static-auth-secret.
# R-1: keep the credential TTL short (5 min) — long enough to establish ICE.
TURN_SECRET=
TURN_TTL_SECONDS=300
TURN_URI=turn:turn.example.org:3478
TURNS_URI=turns:turn.example.org:5349?transport=tcp
# Set to 1 ONLY when behind a trusted reverse proxy that sets X-Forwarded-For
# (e.g. Caddy, which does by default). If the server is directly
# internet-exposed, leave unset — otherwise clients can spoof their IP.
TRUST_PROXY=1
# Per-socket message rate limit (token bucket) — generous, since ICE
# candidate bursts are normal.
MSG_BURST=60
MSG_PER_SEC=30
# Per-source-IP CONNECT attempt budget (bounds host-ID probing regardless of
# hit/miss outcome).
CONNECT_BURST=30
