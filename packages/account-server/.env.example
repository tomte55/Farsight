# @farsight/account-server — environment (see src/config.ts for parsing/defaults)
# Copy to .env for local runs; provide real values as secrets at deploy time.

# HTTP listen port. Default 8090 (the signaling server uses 8080).
PORT=8090

# REQUIRED. JWT signing secret for access/refresh tokens. MUST be >= 32 bytes.
# Generate one, e.g.:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# The server refuses to start without a strong secret. NEVER commit the real value.
ACCOUNT_JWT_SECRET=

# Public base URL where verify/reset links are hosted (goes into emails).
# Defaults to http://127.0.0.1:<PORT> for local dev.
ACCOUNT_BASE_URL=https://auth.sovexa.org

# Prisma SQLite database URL. Defaults to file:./account.db for local dev.
# In Docker, point this at a mounted volume.
DATABASE_URL=file:./account.db

# Email transport: if RESEND_API_KEY is set, real email is sent via Resend and
# ACCOUNT_EMAIL_FROM is REQUIRED. If unset, a stdout dev transport is used
# (emails are logged, not sent). Store the key as a secret — never commit it.
RESEND_API_KEY=
ACCOUNT_EMAIL_FROM=Farsight <no-reply@sovexa.org>

# Set to 1 ONLY behind a trusted reverse proxy that sets X-Forwarded-For (Caddy).
# If directly internet-exposed, leave unset — otherwise clients can spoof their IP.
TRUST_PROXY=1
