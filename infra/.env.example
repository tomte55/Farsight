# infra/.env.example — copy to infra/.env and fill in for your deployment.
# Domains you control, each pointed (DNS A record) at this server's public IP:
SIGNAL_DOMAIN=signal.example.org
TURN_DOMAIN=turn.example.org
# Local OS user that owns the signaling server's .env on this host:
DEPLOY_USER=youruser
# Where the signaling server compose project lives on this host:
SIGNAL_COMPOSE_DIR=/srv/compose/farsight
